# ---- LLM (OpenRouter, OpenAI-compatible) ----
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
# DeepSeek V4 Flash: smarter, cheaper, formats tables well. Its reasoning is
# auto-suppressed in code (rag/pipeline._reasoning_kwargs) so the first token is
# fast. Swap to openai/gpt-4o-mini for the snappiest latency.
LLM_MODEL=deepseek/deepseek-v4-flash

# ---- Embeddings (bge-m3 via OpenRouter — SAME key as the LLM, OpenAI-compatible) ----
EMBED_BASE_URL=https://openrouter.ai/api/v1
EMBED_API_KEY=            # paste the same OpenRouter key as LLM_API_KEY
EMBED_MODEL=baai/bge-m3
EMBED_DIM=1024
# Fallback provider (only if needed):
# EMBED_BASE_URL=https://api.deepinfra.com/v1/openai
# EMBED_MODEL=BAAI/bge-m3

# ---- Vector store ----
# Leave QDRANT_URL empty -> local file mode (zero account, good for dev).
# Set QDRANT_URL + QDRANT_API_KEY -> Qdrant Cloud free tier (the "cloud" version).
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_PATH=./qdrant_local
COLLECTION=crafting

# ---- Retrieval tuning ----
TOP_K=12
RERANK_TOP=4
SCORE_THRESHOLD=0.5
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# ---- App ----
# Set a password to gate the demo (recommended for the deployed Space).
# Leave empty for local dev.
APP_PASSWORD=

# ---- Web-search fallback: DuckDuckGo (free, no key) + Jina fetch. Default ON. ----
WEB_SEARCH=true
# Comma-separated allow-list; the fallback only keeps results from these domains.
INCLUDE_DOMAINS=minecraft.wiki
